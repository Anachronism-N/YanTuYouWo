# SiliconFlow API 配置
SILICONFLOW_API_KEY=sk-your-api-key-here
SILICONFLOW_BASE_URL=https://api.siliconflow.cn/v1

# 数据库配置（初期 SQLite，后期可切换 PostgreSQL）
DATABASE_URL=sqlite+aiosqlite:///./data/yantu_crawl.db

# 爬虫配置
CRAWL_CONCURRENCY=5
CRAWL_DELAY_MIN=2.0
CRAWL_DELAY_MAX=5.0
CRAWL_RETRY_TIMES=3

# 文件存储
HTML_SNAPSHOT_DIR=./data/snapshots

# 日志级别
LOG_LEVEL=INFO
