# ══════════════════════════════════════
# 研途有我 — 后端环境变量配置
# ══════════════════════════════════════

# ── 数据库 ──
# 留空 = 使用爬虫系统的 SQLite（开发模式）
# PostgreSQL 示例: postgresql+asyncpg://user:pass@localhost:5432/yantu
DATABASE_URL=

# ── CORS 允许的源 ──
# 多个域名逗号分隔
# 开发: http://localhost:3000
# 生产: https://your-domain.com
CORS_ORIGINS=http://localhost:3000

# ── JWT ──
# ⚠️ 生产环境必须修改！使用 python -c "import secrets; print(secrets.token_hex(32))" 生成
JWT_SECRET_KEY=yantu-dev-secret-change-in-production-2026
JWT_ALGORITHM=HS256
JWT_EXPIRE_DAYS=7

# ── AI / LLM ──
# 留空 = AI 功能自动降级为 Mock 模式
# SiliconFlow: https://api.siliconflow.cn/v1
# DeepSeek: https://api.deepseek.com/v1
# 自部署: http://your-server:8080/v1
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.siliconflow.cn/v1
OPENAI_MODEL=Qwen/Qwen2.5-7B-Instruct

# ── 调试模式 ──
# true = 开发模式（显示 Swagger 文档 + 详细日志）
# false = 生产模式（隐藏文档 + 强制校验 JWT_SECRET_KEY）
DEBUG=true
